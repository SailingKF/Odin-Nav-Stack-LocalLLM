<?xml version="1.0"?>
<mvsim_world version="1.0">
  <simul_timestep>0</simul_timestep>

  <gui>
    <show_forces>false</show_forces>
    <show_sensor_points>false</show_sensor_points>
  </gui>

  <element class="horizontal_plane">
    <elevation>0</elevation>
    <color>#EBEBEB</color>
    <x_min>-8</x_min>
    <x_max>10</x_max>
    <y_min>-6</y_min>
    <y_max>6</y_max>
    <texture_size>8</texture_size>
  </element>

  <element class="ground_grid">
    <floating>true</floating>
    <color>#A6A6A6</color>
  </element>

  <include file="../definitions/odin_tour_bot.vehicle.xml" />

  <!-- Round 035 baseline: align the minimal live-runtime start pose with the first current POI. -->
  <vehicle name="tour_bot" class="odin_tour_bot">
    <init_pose>0.0 0.0 0.0</init_pose>
    <publish>
      <publish_pose_topic>/tour_bot/pose</publish_pose_topic>
      <publish_pose_period>0.10</publish_pose_period>
    </publish>
  </vehicle>

  <walls>
    <color>#505050</color>
    <wallThickness>0.12</wallThickness>
    <wallHeight>1.0</wallHeight>
    <shape>
      <pt>-4.0 -3.0</pt> <pt>7.0 -3.0</pt>
      <pt>7.0 -3.0</pt> <pt>7.0 3.0</pt>
      <pt>7.0 3.0</pt> <pt>-4.0 3.0</pt>
      <pt>-4.0 3.0</pt> <pt>-4.0 -3.0</pt>
      <pt>-0.5 -3.0</pt> <pt>-0.5 0.8</pt>
      <pt>2.4 -0.3</pt> <pt>5.2 -0.3</pt>
    </shape>
  </walls>
</mvsim_world>
